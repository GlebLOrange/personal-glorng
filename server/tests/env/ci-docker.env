# Complete Settings contract for Docker-based CI jobs (copied to repo-root .env).
APP_ENV=development
ENABLE_MONGODB=true
ENABLE_POSTGRES=false
PRIMARY_DATABASE=mongodb
RUN_MIGRATIONS=false
RUN_SEED=false
SEED_DEMO_COUNT=50
MONGODB_USER=glorng
MONGODB_PASSWORD=glorng_ci_mongodb_123
MONGODB_DB=glorng
MONGODB_URL=mongodb://glorng:glorng_ci_mongodb_123@mongodb:27017/glorng?authSource=admin
POSTGRES_USER=glorng
POSTGRES_PASSWORD=glorng_ci
POSTGRES_DB=glorng
DATABASE_URL=postgresql+asyncpg://glorng:glorng_ci@db:5432/glorng
ELASTICSEARCH_URL=
ELASTICSEARCH_INDEX=search_documents
