# ── App ───────────────────────────────────────────────────
APP_ENV=development
APP_NAME=Gleb.Y
BASE_URL=http://localhost
MEDIA_DIR=/app/media
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000
LOG_REQUESTS=true
LOG_REQUEST_BODIES=false
APP_LOG_PERSIST_ENABLED=true
APP_LOG_PERSIST_MIN_LEVEL=INFO
APP_LOG_RETENTION_DAYS=30

# ── Database bootstrap ────────────────────────────────────
# RUN_MIGRATIONS / RUN_SEED are read from .env only — not Docker Compose overrides.
ENABLE_MONGODB=true
ENABLE_POSTGRES=false
PRIMARY_DATABASE=mongodb
RUN_MIGRATIONS=true
RUN_SEED=true
SEED_DEMO_COUNT=50

# ── MongoDB (primary) ─────────────────────────────────────
MONGODB_USER=user_mongodb
MONGODB_PASSWORD=password_mongodb
MONGODB_DB=db_mongodb
MONGODB_URL=mongodb://${MONGODB_USER}:${MONGODB_PASSWORD}@mongodb:27017/${MONGODB_DB}?authSource=admin

# ── PostgreSQL (optional secondary: search FTS + audit) ───
POSTGRES_USER=user_postgres
POSTGRES_PASSWORD=password_postgres
POSTGRES_DB=db_postgres
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Elasticsearch (optional; requires `make dev-search` or --profile search) ──
# Leave empty for `make dev-lite` — MongoDB (and optional Postgres FTS) handle search.
# ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_URL=
ELASTICSEARCH_INDEX=search_documents

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=password_redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── RabbitMQ / Celery ─────────────────────────────────────
RABBITMQ_USER=user_rabbitmq
RABBITMQ_PASSWORD=password_rabbitmq
CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672//
CELERY_TASK_ALWAYS_EAGER=false

# ── Auth & JWT ────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# Firebase Auth (Google sign-in) and client analytics
FIREBASE_AUTH_ENABLED=false
FIREBASE_PROJECT_ID=
# Prefer GOOGLE_APPLICATION_CREDENTIALS in deployed envs; JSON is useful for local/secret stores.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Email ─────────────────────────────────────────────────
EMAIL_BACKEND=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hleb.y.io

# ── Sentry (disabled in development by default) ───────────
SENTRY_ENABLED=false
SERVER_SENTRY_DSN=
SERVER_SENTRY_RELEASE=

# ── Telegram bot ──────────────────────────────────────────
TELEGRAM_BOT_TO_DO_TOKEN=
TELEGRAM_BOT_CHAT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=0
TIMEZONE=Europe/Warsaw
EXPENSE_DEFAULT_CURRENCY=PLN
TASK_INTAKE_AI_ENABLED=true
TASK_INTAKE_CONFIDENCE_THRESHOLD=0.7

# ── Google Calendar ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── GitHub OAuth ─────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/callback
GITHUB_ALLOWED_USERS=glorange
GITHUB_PUBLIC_USERNAME=glorange

# ── AI (OpenAI-compatible chat & search) ─────────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1
LLM_BASE_URL=
AI_CHAT_ENABLED=true
AI_SEARCH_ENABLED=true

# ── Curated news (disabled until sources/channel are configured) ─
NEWS_INGEST_ENABLED=false
NEWS_SOURCES_JSON=[]
NEWS_INGEST_MAX_ITEMS_PER_RUN=10
NEWS_TELEGRAM_BOT_TOKEN=
NEWS_TELEGRAM_CHANNEL_ID=

# ── Donations ─────────────────────────────────────────────
STRIPE_LINK=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DONATION_AMOUNT_CENTS=500
STRIPE_DONATION_CURRENCY=usd
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
PAYPAL_DONATION_LINK=
PATREON_LINK=
TELEGRAM_LINK=
CRYPTO_BTC_ADDRESS=
CRYPTO_ETH_ADDRESS=

# ── Inbound webhooks (slug → HMAC secret, JSON object) ────
WEBHOOK_SECRETS=

# ── Spotify (now playing banner) ──────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ── Weather ───────────────────────────────────────────────
WEATHER_DEFAULT_LABEL=Wrocław
WEATHER_DEFAULT_QUERY=Wroclaw
WORLD_TIME_API_BASE=https://timeapi.world/api

# ── Seed / E2E ────────────────────────────────────────────
ALLOWED_EMAIL=admin@admin.admin
SEED_PASSWORD=password_seed
E2E_EMAIL=admin@admin.admin
E2E_PASSWORD=password_seed

# ── Test-only (leave false/empty in production) ───────────
USE_SQLITE_TESTS=false
POSTGRES_TEST_URL=

# ── Frontend dev (host Vite with `make dev-lite-client`) ─────────
# Default for host dev is in client/.env.development (VITE_API_PROXY_TARGET=http://127.0.0.1:8000).
# Override here only if you need a non-default proxy target.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
# VITE_BEHIND_NGINX=true
# VITE_SENTRY_ENABLED=false
# VITE_CLIENT_SENTRY_DSN=
# VITE_CLIENT_SENTRY_RELEASE=
# VITE_FIREBASE_ENABLED=false
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_AI_CHAT_ENABLED=true
# VITE_AI_SEARCH_ENABLED=true

# ── Ultra-lite dev (`make dev-ultra-lite-infra` + `make dev-ultra-lite-server`) ─────────
# Host API: Makefile sets CELERY_TASK_ALWAYS_EAGER=true and MEDIA_DIR=./server/media.
# Keep REDIS_URL/MONGODB_URL with compose hostnames — settings remap to 127.0.0.1 off-container.
# Use `make dev-worker` when you need real async Celery jobs (RabbitMQ).

# ── Backups (scripts/db_maintenance.sh) ───────────────────
# BACKUP_DIR=./backups
# BACKUP_RETENTION_DAYS=7
# BACKUP_RETENTION_WEEKS=4
# BACKUP_COMPOSE_FILE=docker-compose.prod.yml
# BACKUP_NOTIFY=true
# BACKUP_TIMEZONE=Europe/Warsaw

# ── Prod → dev pull (scripts/pull_prod_db.sh, manual only) ─
# CONFIRM_PROD_PULL=1
# PROD_BACKUP_PATH=/path/to/glorng_latest.dump.gz
# PROD_SSH_HOST=user@prod-host
# PROD_BACKUP_DIR=/var/backups/glorng/postgres/glorng_latest.dump.gz
# LOCAL_COMPOSE_FILE=docker-compose.yml
