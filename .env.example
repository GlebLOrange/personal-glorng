# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=glorng
POSTGRES_PASSWORD=glorng
POSTGRES_DB=glorng

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── RabbitMQ / Celery ─────────────────────────────────────
RABBITMQ_USER=glorng
RABBITMQ_PASSWORD=replace-with-rabbitmq-password
CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672//

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── Auth ──────────────────────────────────────────────────
# Seed/bootstrap email for the initial superuser (registration is open to all)
ALLOWED_EMAIL=admin@glorng.dev

# ── Email ─────────────────────────────────────────────────
EMAIL_BACKEND=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@glorng.dev

# ── Sentry (disabled in development by default) ───────────
SENTRY_ENABLED=false
VITE_SENTRY_ENABLED=false
SERVER_SENTRY_DSN=
SERVER_SENTRY_RELEASE=
VITE_CLIENT_SENTRY_DSN=
VITE_CLIENT_SENTRY_RELEASE=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TO_DO_TOKEN=
TELEGRAM_BOT_CHAT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=0
TIMEZONE=Europe/Warsaw
EXPENSE_DEFAULT_CURRENCY=PLN

# ── Google Calendar ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── GitHub OAuth ─────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/callback
GITHUB_ALLOWED_USERS=glorange

# ── AI Provider (OpenAI-compatible chat) ─────────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1
# Optional: point at Groq, Ollama, OpenRouter, etc. Leave empty for OpenAI default.
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_BASE_URL=https://openrouter.ai/api/v1

# ── Donations ─────────────────────────────────────────────
STRIPE_LINK=
TELEGRAM_LINK=
CRYPTO_BTC_ADDRESS=
CRYPTO_ETH_ADDRESS=

# ── Spotify (now playing banner) ──────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
# OAuth helper only — must match Spotify Dashboard → Redirect URIs exactly (no localhost)
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ── Google Analytics (disabled — set VITE_GA_ENABLED=true to re-enable) ──
VITE_GA_ENABLED=false
VITE_GA_ID=

# ── Database bootstrap (optional) ─────────────────────────
# RUN_MIGRATIONS=true   # set on server in dev compose; prod uses migrate service only
# RUN_SEED=false        # set true with `docker compose run -e RUN_SEED=true --rm migrate` for first-time seed

# ── Seed ──────────────────────────────────────────────────
SEED_PASSWORD=

# ── AI Chat / Search ──────────────────────────────────────
AI_CHAT_ENABLED=true
AI_SEARCH_ENABLED=true
VITE_AI_CHAT_ENABLED=true
VITE_AI_SEARCH_ENABLED=true

# ── Task intake (Telegram /new — needs OPENAI_API_KEY when enabled) ──
TASK_INTAKE_AI_ENABLED=true
TASK_INTAKE_CONFIDENCE_THRESHOLD=0.7

# ── CORS (required in production) ─────────────────────────
# Comma-separated or JSON array; must match your public site origin(s).
# CORS_ORIGINS=http://localhost,http://localhost:80,https://glorng.com

# ── App ───────────────────────────────────────────────────
APP_ENV=development
LOG_REQUESTS=true
APP_NAME=Gleb Y.
BASE_URL=http://localhost

# ── Backups (scripts/db_maintenance.sh) ───────────────────
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_WEEKS=4
BACKUP_COMPOSE_FILE=docker-compose.prod.yml
BACKUP_NOTIFY=true
BACKUP_TIMEZONE=Europe/Warsaw
# BACKUP_CRON_LOG=./logs/backup.log

# ── Prod → dev pull (scripts/pull_prod_db.sh, manual only) ─
# CONFIRM_PROD_PULL=1
# PROD_BACKUP_PATH=/path/to/glorng_latest.dump.gz
# PROD_SSH_HOST=user@prod-host
# PROD_BACKUP_DIR=/var/backups/glorng/postgres/glorng_latest.dump.gz
# LOCAL_COMPOSE_FILE=docker-compose.yml

# ── Frontend dev (host Vite with `make dev-lite`) ─────────
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
# VITE_BEHIND_NGINX=true   # set automatically in docker-compose client service
