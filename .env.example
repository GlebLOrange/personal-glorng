# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=glorng
POSTGRES_PASSWORD=glorng
POSTGRES_DB=glorng

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── Auth ──────────────────────────────────────────────────
ALLOWED_EMAIL=admin@glorng.dev

# ── Email ─────────────────────────────────────────────────
EMAIL_BACKEND=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@glorng.dev

# ── Sentry ────────────────────────────────────────────────
SERVER_SENTRY_DSN=
SERVER_SENTRY_RELEASE=
VITE_CLIENT_SENTRY_DSN=
VITE_CLIENT_SENTRY_RELEASE=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TO_DO_TOKEN=
TELEGRAM_BOT_CHAT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=0
TIMEZONE=Europe/Warsaw

# ── Google Calendar ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── GitHub OAuth ─────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/callback
GITHUB_ALLOWED_USERS=glorange

# ── AI Provider API Keys ──────────────────────────────────
GROQ_API_KEY=

# ── Donations ─────────────────────────────────────────────
STRIPE_LINK=
TELEGRAM_LINK=
CRYPTO_BTC_ADDRESS=
CRYPTO_ETH_ADDRESS=

# ── Spotify (now playing banner) ──────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
# OAuth helper only — must match Spotify Dashboard → Redirect URIs exactly (no localhost)
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ── Google Analytics (disabled — set VITE_GA_ENABLED=true to re-enable) ──
VITE_GA_ENABLED=false
VITE_GA_ID=

# ── Seed ──────────────────────────────────────────────────
SEED_PASSWORD=

# ── AI Chat (disabled — set both to true to re-enable) ───
AI_CHAT_ENABLED=false
VITE_AI_CHAT_ENABLED=false

# ── App ───────────────────────────────────────────────────
APP_ENV=development
APP_NAME=gLOrng
BASE_URL=http://localhost
