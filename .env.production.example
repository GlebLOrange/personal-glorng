# Production-oriented template. Copy to `.env` on the host and fill blanks.
# Prefer process env / Docker secrets for individual overrides — Settings reads
# process env before dotenv (see docs/reference/configuration.md).

APP_ENV=production
APP_NAME=Gleb.Y
BASE_URL=https://example.com
MEDIA_DIR=/app/media
CORS_ORIGINS=https://example.com
LOG_REQUESTS=true
LOG_REQUEST_BODIES=false
APP_LOG_PERSIST_ENABLED=true
APP_LOG_PERSIST_MIN_LEVEL=INFO
APP_LOG_RETENTION_DAYS=30

ENABLE_MONGODB=true
ENABLE_POSTGRES=false
PRIMARY_DATABASE=mongodb
RUN_MIGRATIONS=false
RUN_SEED=false

MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB=glorng
MONGODB_URL=mongodb://${MONGODB_USER}:${MONGODB_PASSWORD}@mongodb:27017/${MONGODB_DB}?authSource=admin

REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_CACHE_URL=redis://:${REDIS_PASSWORD}@redis-cache:6379/0

RABBITMQ_USER=glorng
RABBITMQ_PASSWORD=
CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672//

JWT_SECRET=
FERNET_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

ALLOWED_EMAIL=
SEED_PASSWORD=
EMAIL_BACKEND=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
